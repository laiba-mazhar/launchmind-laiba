# ── Slack final summary ───────────────────────────────────────────────────────

def _post_final_summary(idea: str, spec: dict, copy: dict, pr_url: str, issue_url: str) -> None:
    blocks = [
        {
            "type": "header",
            "text": {"type": "plain_text", "text": "✅ LaunchMind — Mission Complete"},
        },
        {"type": "divider"},
        {
            "type": "section",
            "text": {
                "type": "mrkdwn",
                "text": f"*Startup Idea:* {idea}\n*Value Proposition:* {spec['value_proposition']}",
            },
        },
        {
            "type": "section",
            "fields": [
                {"type": "mrkdwn", "text": f"*Tagline:*\n_{copy.get('tagline', 'N/A')}_"},
                {"type": "mrkdwn", "text": f"*Startup Name:*\n{copy.get('startup_name', 'N/A')}"},
                {"type": "mrkdwn", "text": f"*GitHub PR:*\n<{pr_url}|View PR>"},
                {"type": "mrkdwn", "text": f"*GitHub Issue:*\n<{issue_url}|View Issue>"},
            ],
        },
        {
            "type": "section",
            "text": {
                "type": "mrkdwn",
                "text": "*Top Features Built:*\n"
                + "\n".join(
                    f"• *{f['name']}* — {f['description']}"
                    for f in spec["features"][:3]
                ),
            },
        },
        {"type": "divider"},
        {
            "type": "context",
            "elements": [
                {"type": "mrkdwn", "text": "_Final summary by LaunchMind CEO Agent_ 🤖"}
            ],
        },
    ]

    r = requests.post(
        "https://slack.com/api/chat.postMessage",
        headers={
            "Authorization": f"Bearer {SLACK_BOT_TOKEN}",
            "Content-Type": "application/json",
        },
        json={"channel": SLACK_CHANNEL, "blocks": blocks},
    )
    data = r.json()
    if data.get("ok"):
        print("[CEO] Final Slack summary posted.")
    else:
        print(f"[CEO] Slack error: {data.get('error')}")


# ── Decision log ──────────────────────────────────────────────────────────────

_decision_log: list[dict] = []


def _log(agent: str, verdict: str, action: str, feedback: str = "") -> None:
    entry = {"agent": agent, "verdict": verdict, "action": action, "feedback": feedback}
    _decision_log.append(entry)
    print(f"[CEO] Decision → agent={agent} | verdict={verdict} | action={action}")
    if feedback:
        print(f"         feedback: {feedback}")


def get_decision_log() -> list[dict]:
    return list(_decision_log)


# ── Orchestration ─────────────────────────────────────────────────────────────

def dispatch_to_product(idea: str, focus: str) -> None:
    bus.send_message("ceo", "product", "task", {"idea": idea, "focus": focus})


def dispatch_revision_to_product(idea: str, feedback: str) -> None:
    bus.send_message(
        "ceo", "product", "revision_request",
        {"idea": idea, "focus": feedback},
    )


def dispatch_to_qa(html: str, copy: dict, spec: dict, pr_url: str) -> None:
    bus.send_message(
        "ceo", "qa", "task",
        {"html": html, "copy": copy, "spec": spec, "pr_url": pr_url},
    )


def post_final_summary(idea: str, spec: dict, copy: dict, pr_url: str, issue_url: str) -> None:
    _post_final_summary(idea, spec, copy, pr_url, issue_url)
    # Also send as a message to self for log completeness
    bus.send_message(
        "ceo", "ceo", "result",
        {
            "status": "complete",
            "pr_url": pr_url,
            "issue_url": issue_url,
            "startup_name": copy.get("startup_name"),
        },
    )
