"""
agents/ceo_agent.py
CEO Agent — orchestrator. Decomposes idea, dispatches tasks, reviews outputs,
runs feedback loops, posts final Slack summary.
Owner: [Student Name]
"""

import json
import os

import requests
from openai import OpenAI

import message_bus as bus

client = OpenAI(api_key=os.environ["OPENAI_API_KEY"])

SLACK_BOT_TOKEN = os.environ["SLACK_BOT_TOKEN"]
SLACK_CHANNEL = "#launches"

MAX_REVISION_CYCLES = 2     # CEO will ask for at most this many revisions per agent


# ── LLM ──────────────────────────────────────────────────────────────────────

def _call_llm(system: str, user: str) -> str:
    response = client.chat.completions.create(
        model="gpt-4o",
        messages=[
            {"role": "system", "content": system},
            {"role": "user", "content": user},
        ],
        temperature=0.5,
    )
    return response.choices[0].message.content.strip()


def _parse_json(raw: str) -> dict:
    clean = raw.strip()
    if clean.startswith("```"):
        clean = clean.split("```")[1]
        if clean.startswith("json"):
            clean = clean[4:]
    return json.loads(clean.strip())


# ── Decision helpers ──────────────────────────────────────────────────────────

def decompose_idea(idea: str) -> dict:
    """LLM call #1: break the startup idea into tasks for each agent."""
    print("[CEO] Decomposing startup idea into agent tasks...")
    raw = _call_llm(
        "You are a startup CEO. Decompose work into precise instructions for your team. Return only valid JSON.",
        f"""
Startup idea: "{idea}"

Create specific task instructions for each team member. Return JSON:
{{
  "product_focus": "specific instructions for the product manager — what to focus on",
  "engineer_focus": "specific instructions for the engineer — what to emphasise in the landing page",
  "marketing_focus": "specific instructions for the marketer — tone, target audience emphasis"
}}
""",
    )
    tasks = _parse_json(raw)
    print(f"[CEO] Tasks decomposed.")
    return tasks


def review_product_spec(spec: dict, idea: str) -> dict:
    """LLM call #2: review the product spec and decide pass/fail."""
    print("[CEO] Reviewing product spec...")
    raw = _call_llm(
        "You are a critical CEO reviewing your product manager's work. Be demanding. Return only valid JSON.",
        f"""
Original idea: "{idea}"

Product spec to review:
{json.dumps(spec, indent=2)}

Assess rigorously:
1. Is the value proposition specific (not generic)?
2. Are the personas realistic with concrete pain points?
3. Are the 5 features concrete and prioritised logically?
4. Are the user stories well-formed?

Return JSON:
{{
  "verdict": "pass" or "fail",
  "feedback": "if fail: specific list of what needs to be fixed. If pass: empty string."
}}
""",
    )
    return _parse_json(raw)


